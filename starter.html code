  <style>
    :root{
      --bg:#000;
      --panel:#0b0b0b;
      --text:#fff;
      --muted:rgba(255,255,255,0.72);
      --border:rgba(255,255,255,0.10);
      --red:#ff2d2d;
      --red2:#ff5a5a;
    }

    *{box-sizing:border-box;}

    body{
      margin:0;
      background:var(--bg);
      color:var(--text);
      font-family:-apple-system,BlinkMacSystemFont,"Inter",Arial,sans-serif;
      line-height:1.6;
      -webkit-font-smoothing:antialiased;
      text-align:center;
    }

    header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:16px 20px;
      background:rgba(0,0,0,0.75);
      border-bottom:1px solid var(--border);
      position:sticky;
      top:0;
      z-index:50;
      backdrop-filter:blur(10px);
    }

    header img{
      width:250px;
      height:auto;
    }

    .nav-btn{
      background:transparent;
      color:#fff;
      border:1px solid var(--border);
      padding:10px 16px;
      border-radius:10px;
      text-decoration:none;
      font-weight:700;
      font-size:15px;
    }

    .wrap{
      max-width:900px;
      margin:0 auto;
      padding:30px 18px 50px;
    }

    .hero{
      max-width:760px;
      margin:0 auto 30px;
    }

    .tag{
      display:inline-block;
      padding:8px 12px;
      border:1px solid var(--border);
      border-radius:999px;
      color:var(--muted);
      font-weight:800;
      background:rgba(255,255,255,0.03);
      margin-bottom:16px;
    }

    h1{
      font-size:36px;
      line-height:1.15;
      margin:0 0 14px;
    }

    .sub{
      color:var(--muted);
      font-size:17px;
      max-width:700px;
      margin:0 auto;
    }

    .steps{
      display:grid;
      gap:14px;
      margin:34px auto 24px;
      max-width:760px;
    }

    .step{
      background:linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
      border:1px solid var(--border);
      border-radius:14px;
      padding:18px;
      text-align:left;
    }

    .step-number{
      display:inline-block;
      font-size:13px;
      font-weight:900;
      color:var(--red2);
      margin-bottom:6px;
      letter-spacing:.3px;
      text-transform:uppercase;
    }

    .step h2{
      margin:0 0 8px;
      font-size:20px;
    }

    .step p{
      margin:0;
      color:var(--muted);
      font-size:15px;
    }

    .offer-box{
      max-width:760px;
      margin:30px auto 0;
      padding:20px;
      border:1px solid var(--border);
      border-radius:14px;
      background:rgba(255,255,255,0.03);
      text-align:left;
    }

    .offer-box h3{
      margin:0 0 10px;
      font-size:22px;
    }

    .offer-box ul{
      margin:0;
      padding-left:20px;
      color:var(--muted);
    }

    .offer-box li{
      margin:8px 0;
    }

    .cta{
      margin-top:28px;
    }

    .cta-btn{
      background:var(--red);
      color:#fff;
      padding:14px 24px;
      border-radius:12px;
      text-decoration:none;
      font-weight:900;
      display:inline-block;
      box-shadow:0 10px 25px rgba(255,45,45,0.18);
    }

    .small{
      margin-top:14px;
      color:rgba(255,255,255,0.56);
      font-size:13px;
      max-width:720px;
      margin-left:auto;
      margin-right:auto;
    }

    footer{
      margin-top:50px;
      padding:30px 18px;
      border-top:1px solid #222;
      color:#888;
      font-size:13px;
    }

    @media (min-width: 720px){
      h1{font-size:44px;}
      header img{width:280px;}
    }
  </style>
</head>
